# Configuration template for PDF Toolkit
# Copy this to .env and modify as needed

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
MAX_FILES_PER_REQUEST=10

# Storage Directories
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs

# Cleanup Configuration
CLEANUP_ENABLED=true
CLEANUP_HOURS=24  # Delete files older than 24 hours

# Logging
LOG_LEVEL=INFO
LOG_FILE=pdf-toolkit.log

# Compression Settings
DEFAULT_COMPRESSION_QUALITY=ebook  # screen, ebook, printer, prepress

# Image Conversion
DEFAULT_IMAGE_DPI=150  # 100, 150, 200, 300
DEFAULT_IMAGE_FORMAT=png  # png, jpg

# Security
ENABLE_CORS=true
ALLOWED_ORIGINS=*

# Performance
WORKERS=4  # Number of uvicorn workers (adjust based on CPU cores)
REQUEST_TIMEOUT=300  # Timeout in seconds

# Features
ENABLE_COMPRESSION=true
ENABLE_MERGE=true
ENABLE_SPLIT=true
ENABLE_CONVERSION=true
ENABLE_SECURITY=true
ENABLE_WATERMARK=true
ENABLE_PREVIEW=true
